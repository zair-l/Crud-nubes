{
  "compilerOptions": {
    "outDir": "./dist",       
    "rootDir": "./",       

    "target": "es2020",       
    "module": "CommonJS",     

    "esModuleInterop": true,  
    "forceConsistentCasingInFileNames": true,
    "strict": true,           
